// This is your Prisma schema file for the
// AFH Digital Archive project.

datasource db {
  provider = "postgresql" // This will use the DATABASE_URL from .env
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMERATIONS ---
// Used in the User model
enum Role {
  STUDENT
  MENTOR
  ADMIN
}

// Used in the Artwork model
enum ArtworkStatus {
  PENDING
  APPROVED
  REJECTED
}

// Used in the AdminAction model
enum AdminActionType {
  ARTWORK_APPROVED
  ARTWORK_REJECTED
  ARTWORK_FEATURED
  ARTWORK_UNFEATURED
  USER_EDITED
}

// --- MODELS ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password_hash String
  role          Role      @default(STUDENT)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Relations
  profile           Profile?
  artworks          Artwork[]      @relation("ArtworkAuthor") // Artworks this user created
  approved_artworks Artwork[]      @relation("ArtworkApprover") // Artworks this user approved
  admin_actions     AdminAction[]  @relation("AdminActor") // Actions this admin has taken
}

model Profile {
  id                  String   @id @default(uuid())
  user_id             String   @unique // This enforces the 1-to-1 relation
  display_name        String?  @db.VarChar(255)
  bio                 String?
  profile_image_url   String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade) // Deleting a user deletes their profile
}

model Artwork {
  id                   String    @id @default(uuid())
  title                String    @db.VarChar(500)
  description          String?
  tools_used           String[] // This is your TEXT[] array
  project_type         String?   @db.VarChar(100)
  image_url            String
  thumbnail_url        String?
  status               ArtworkStatus @default(PENDING)
  submitted_by_name    String?   @db.VarChar(255)
  submitted_by_email   String?   @db.VarChar(255)
  rejection_reason     String?
  featured             Boolean   @default(false)
  view_count           Int       @default(0)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  approved_at          DateTime?

  // Relational Fields
  // The artist/author who submitted it (nullable for guest uploads)
  author    User?   @relation("ArtworkAuthor", fields: [user_id], references: [id])
  user_id   String? // Foreign key for the author (null for guest uploads)
  
  // The admin who approved it (nullable)
  approver     User?   @relation("ArtworkApprover", fields: [approved_by_id], references: [id])
  approved_by_id String? // Foreign key for the approver

  // Relations
  admin_actions AdminAction[]

  // --- INDEXES ---
  // These are from your diagram for performance
  @@index([status], name: "idx_artworks_status")
  @@index([featured], name: "idx_artworks_featured")
  @@index([user_id], name: "idx_artworks_user_id")
  @@index([created_at(sort: Desc)], name: "idx_artworks_created_at")
}

model AdminAction {
  id          String   @id @default(uuid())
  action_type AdminActionType
  metadata    Json?    // This is your JSONB field
  created_at  DateTime @default(now())

  // Relational Fields
  // The admin who performed the action
  admin      User   @relation("AdminActor", fields: [admin_id], references: [id])
  admin_id   String // Foreign key for the admin
  
  // The artwork the action was related to
  artwork    Artwork @relation(fields: [artwork_id], references: [id], onDelete: Cascade)
  artwork_id String // Foreign key for the artwork
}